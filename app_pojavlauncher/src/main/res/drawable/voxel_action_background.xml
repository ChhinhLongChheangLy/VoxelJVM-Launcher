<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#263B58" />
            <stroke android:width="1dp" android:color="@color/voxel_cyan" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="@color/voxel_surface" />
            <stroke android:width="1dp" android:color="@color/voxel_outline" />
        </shape>
    </item>
</selector>
