<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#07101F"
                android:centerColor="#0A1629"
                android:endColor="#0D2031" />
        </shape>
    </item>
    <item android:gravity="top|right" android:width="220dp" android:height="220dp" android:right="-80dp" android:top="-90dp">
        <shape android:shape="oval">
            <gradient android:type="radial" android:gradientRadius="110dp" android:startColor="#33438DFF" android:endColor="#00438DFF" />
        </shape>
    </item>
</layer-list>
