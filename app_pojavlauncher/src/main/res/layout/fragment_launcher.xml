<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/launch_dock"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="20dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/voxel_card_background"
                android:gravity="center_vertical"
                android:minHeight="178dp"
                android:orientation="horizontal"
                android:padding="22dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/noto_sans_bold"
                        android:letterSpacing="0.15"
                        android:text="@string/voxel_home_eyebrow"
                        android:textColor="@color/voxel_cyan"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/noto_sans_bold"
                        android:lineSpacingExtra="-3dp"
                        android:text="@string/voxel_home_title"
                        android:textColor="@color/primary_text"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:maxWidth="310dp"
                        android:text="@string/voxel_home_subtitle"
                        android:textColor="@color/secondary_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginStart="12dp"
                    android:alpha="0.96"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_voxeljvm_logo" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/noto_sans_bold"
                android:letterSpacing="0.12"
                android:text="@string/voxel_quick_actions"
                android:textColor="@color/secondary_text"
                android:textSize="9sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/news_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_menu_news"
                    android:text="@string/mcl_tab_wiki" />

                <Space android:layout_width="10dp" android:layout_height="1dp" />

                <com.kdt.mcgui.LauncherMenuButton
                    android:id="@+id/discord_button"
                    style="@style/LauncherMenuButton.Universal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_discord"
                    android:text="@string/mcl_button_discord" />
            </LinearLayout>

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/custom_control_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_menu_custom_controls"
                android:text="@string/mcl_option_customcontrol" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/install_jar_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_menu_install_jar"
                android:text="@string/main_install_jar_file" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/share_logs_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:drawableStart="@android:drawable/ic_menu_share"
                android:text="@string/main_share_logs" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/open_files_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:drawableStart="@drawable/ic_folder"
                android:text="@string/mcl_button_open_directory" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/launch_dock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/voxel_top_bar"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/noto_sans_bold"
            android:letterSpacing="0.12"
            android:text="@string/voxel_profile_label"
            android:textColor="@color/voxel_cyan"
            android:textSize="8sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/voxel_icon_button"
                android:drawableEnd="@drawable/spinner_arrow"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                app:drawableEndPadding="1dp"
                app:drawableEndSize="12dp"
                app:drawableStartIntegerScaling="true"
                app:drawableStartSize="34dp" />

            <ImageButton
                android:id="@+id/edit_profile_button"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/voxel_icon_button"
                android:contentDescription="@string/create_profile"
                android:padding="13dp"
                android:src="@drawable/ic_edit_profile" />
        </LinearLayout>

        <com.kdt.mcgui.MineButton
            android:id="@+id/play_button"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:text="@string/main_play"
            android:textColor="@color/voxel_ink"
            android:textSize="15sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
